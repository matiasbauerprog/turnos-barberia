# === Base de datos (PostgreSQL / Supabase) ===
# Cadena de conexión con pooling (usada por Prisma en runtime)
POSTGRES_PRISMA_URL="postgresql://USUARIO:PASSWORD@HOST:5432/postgres"
# Cadena de conexión directa (usada por Prisma para migraciones)
POSTGRES_URL_NON_POOLING="postgresql://USUARIO:PASSWORD@HOST:5432/postgres"

# === Seguridad ===
# Clave para firmar los JWT. Generá una aleatoria y larga, p. ej.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="cambiar-por-una-clave-larga-y-aleatoria"

# === Servidor ===
PORT=3001
